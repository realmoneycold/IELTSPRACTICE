// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum TestType {
  READING
  LISTENING
  WRITING
  SPEAKING
}

enum PracticeMode {
  FULL
  PARTIAL
}

enum QuestionType {
  MULTIPLE_CHOICE
  FILL_BLANKS
  TRUE_FALSE
}

enum ReportType {
  CONTENT_ERROR
  TECHNICAL_BUG
  SCORE_ERROR
  TYPO
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  WONT_FIX
}

// ─── PracticeTest ─────────────────────────────────────────────────────────────
// NEW FIELDS: practiceMode (FULL/PARTIAL), focusArea (String?)
model PracticeTest {
  id            Int           @id @default(autoincrement())
  title         String
  testType      TestType
  practiceMode  PracticeMode  @default(FULL)     // NEW: Full section or specific question focus
  focusArea     String?                           // NEW: e.g. "Matching Headings", "Map Labelling"
  durationMins  Int           @default(60)
  instructions  String?       @db.Text
  passage       String?       @db.Text
  isPublished   Boolean       @default(false)
  isArchived    Boolean       @default(false)
  createdById   Int
  createdBy     Admin         @relation("CreatedTests", fields: [createdById], references: [id])
  questions     Question[]
  reports       Report[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([testType])
  @@index([isPublished])
  @@index([createdById])
  @@index([practiceMode])
}

// ─── Question ────────────────────────────────────────────────────────────────
// Full model for test questions. Supports MC, fill-blanks, true/false.
model Question {
  id            Int          @id @default(autoincrement())
  testId        Int
  test          PracticeTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  questionText  String       @db.Text
  type          QuestionType @default(MULTIPLE_CHOICE)
  // JSON array of strings for MC options e.g. ["Paris","London","Berlin","Madrid"]
  // null for fill_blanks and true_false
  options       Json?
  correctAnswer String
  orderIndex    Int          @default(0)
  reports       Report[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([testId])
  @@index([type])
}

// ─── Report ──────────────────────────────────────────────────────────────────
// Student-submitted reports about content errors, bugs, score issues etc.
model Report {
  id             Int          @id @default(autoincrement())
  studentId      Int
  student        User         @relation("StudentReports", fields: [studentId], references: [id])
  testId         Int
  test           PracticeTest @relation(fields: [testId], references: [id])
  questionId     Int?
  question       Question?    @relation(fields: [questionId], references: [id])
  type           ReportType   @default(CONTENT_ERROR)
  status         ReportStatus @default(OPEN)
  description    String       @db.Text
  resolvedById   Int?
  resolvedBy     Admin?       @relation("ResolvedReports", fields: [resolvedById], references: [id])
  resolutionNote String?      @db.Text
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([studentId])
  @@index([testId])
  @@index([status])
  @@index([type])
}

// ─── AdminTask ────────────────────────────────────────────────────────────────
// Tasks assigned to admin users (used by Task List page)
model AdminTask {
  id           Int      @id @default(autoincrement())
  adminId      Int
  admin        Admin    @relation("AssignedTasks", fields: [adminId], references: [id])
  title        String
  label        String   // 'cs' | 'ta' | 'cm' | 'ops'
  priority     String   @default("med") // 'high' | 'med' | 'low'
  status       String   @default("pending") // 'pending' | 'in_progress' | 'done'
  isDone       Boolean  @default(false)
  doneAt       DateTime?
  assignedDate DateTime @default(now())
  dueDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([adminId])
  @@index([assignedDate])
  @@index([isDone])
}

// ─── Notification ─────────────────────────────────────────────────────────────
// Admin notification tray entries
model Notification {
  id        Int      @id @default(autoincrement())
  icon      String   @default("📢")
  iconBg    String   @default("#f0faf7")
  text      String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  readAt    DateTime?

  @@index([isRead])
  @@index([createdAt])
}

