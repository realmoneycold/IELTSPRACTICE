generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
  CEO
  CENTRE
  TEACHER
}

enum PartnerStatus {
  PENDING
  APPROVED
}

// New enums for CEO Mission Control
enum AdminRole {
  ADMIN
  GRADER
  SUPPORT
  CONTENT
  ANALYST
  MANAGER
}

enum TaskLabel {
  CUSTOMER_SERVICE
  TECHNICAL_ANALYSIS
  CONTENT_MANAGEMENT
  OPERATIONS
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum DeviceType {
  DESKTOP
  LAPTOP
  MOBILE
  TABLET
}

// New enums for Admin Portal v2
enum TestType {
  READING
  LISTENING
  WRITING
  SPEAKING
}

enum PracticeMode {
  FULL
  PARTIAL
}

enum QuestionType {
  MULTIPLE_CHOICE
  FILL_BLANKS
  TRUE_FALSE
}

enum ReportType {
  CONTENT_ERROR
  TECHNICAL_BUG
  SCORE_ERROR
  TYPO
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  WONT_FIX
}

model User {
  id                  Int       @id @default(autoincrement())
  full_name           String
  email               String    @unique
  password            String
  country             String?
  phone               String?
  test_type           String?
  role                Role      @default(STUDENT)
  is_verified         Boolean   @default(false)
  is_onboarded        Boolean   @default(false)
  target_band         Float?    @default(8)
  current_band        Float     @default(5)
  study_hours         Float     @default(0)
  tasks_done          Int       @default(0)
  weekly_goal_percent Float     @default(0)
  best_streak         Int       @default(0)
  avatar_url          String?
  country_flag        String? // e.g., "🇺🇿"
  wpm_score           Int? // Words per minute for leaderboard
  band_trend          String? // e.g., "▲ +0.5"
  band_trend_class    String? // e.g., "up", "down"
  avatar_background   String? // CSS gradient for avatar
  completedModules    Json? // Track completed tests and modules
  exam_date           DateTime?
  exam_date_text      String?
  target_band_range   String?
  study_commitment    String?
  referral_source     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  typingResults  TypingResult[]
  studyStreaks   StudyStreak[]
  weeklyProgress WeeklyProgress[]
  reports        Report[]         @relation("reports")
  lessons        Lesson[]         @relation("lessons")
  materials      Material[]       @relation("materials")
  followers      Follow[]         @relation("followers")
  following      Follow[]         @relation("following")
  userProgress   UserProgress[]   @relation("UserProgress")
}

model UserProgress {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserProgress")
  testNumber  Int // Test 1, 2, 3, etc.
  module      String // "Listening", "Reading", "Writing", "Speaking"
  isCompleted Boolean  @default(false)
  score       Float? // Optional score for the module
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, testNumber, module])
}

model StudyStreak {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  isCompleted Boolean  @default(false)

  @@unique([userId, date])
}

model WeeklyProgress {
  id                 Int      @id @default(autoincrement())
  userId             Int
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate      DateTime @db.Date
  perfectScoresCount Int      @default(0)
  progressPercentage Float    @default(0)

  @@unique([userId, weekStartDate])
}

model PartnerRequest {
  id          Int           @id @default(autoincrement())
  centre_name String
  ceo_name    String
  email       String        @unique
  phone       String
  location    String
  status      PartnerStatus @default(PENDING)
  password    String
  createdAt   DateTime      @default(now())
}

model TypingResult {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wpm             Float
  accuracy        Float
  date            DateTime @default(now())
  durationMinutes Int?     @default(2)
}

model VerificationCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ExamDate {
  id    Int      @id @default(autoincrement())
  date  DateTime
  label String?
}

// ─────────────────────────────────────────────────────────────
// CEO Mission Control Models
// ─────────────────────────────────────────────────────────────

model Admin {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  phone        String?
  passwordHash String // bcrypt hash — never store plaintext
  role         AdminRole @default(GRADER)
  isActive     Boolean   @default(true)
  lastSeenAt   DateTime?

  devices         Device[]
  tasks           AdminTask[]
  createdTests    PracticeTest[] @relation("CreatedTests")
  resolvedReports Report[]       @relation("resolvedReports")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Device {
  id Int @id @default(autoincrement())

  // Linked to an admin (nullable if this is CEO's device)
  adminId Int?
  admin   Admin? @relation(fields: [adminId], references: [id], onDelete: Cascade)

  deviceType DeviceType @default(DESKTOP)
  deviceName String // e.g. "MacBook Pro 16""
  browser    String // e.g. "Chrome 122"
  os         String? // e.g. "Ubuntu 22.04"

  ipAddress String?
  location  String? // e.g. "Tashkent, UZ"  (from IP geo-lookup)
  latitude  Float?
  longitude Float?

  userAgent    String?  @db.Text
  isActive     Boolean  @default(true) // currently logged-in session
  lastActiveAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId])
  @@index([isActive])
}

model AdminTask {
  id Int @id @default(autoincrement())

  adminId Int
  admin   Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  title    String
  notes    String?      @db.Text
  label    TaskLabel    @default(CUSTOMER_SERVICE)
  priority TaskPriority @default(MEDIUM)
  isDone   Boolean      @default(false)
  doneAt   DateTime?

  // Date this task was assigned (for "today's tasks" queries)
  assignedDate DateTime @default(now()) @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId])
  @@index([assignedDate])
  @@index([isDone])
}

model EducationalCentre {
  id           Int     @id @default(autoincrement())
  name         String
  city         String
  district     String?
  address      String?
  contactEmail String?
  contactPhone String?
  websiteUrl   String?

  // Performance metrics (can be computed or manually updated)
  totalStudents  Int    @default(0)
  activeStudents Int    @default(0)
  rating         Float? @default(0.0) // 0.0–5.0

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([isActive])
}

model StrategicGoal {
  id       Int          @id @default(autoincrement())
  title    String
  priority TaskPriority @default(MEDIUM)
  column   String       @default("TODO") // TODO | IN_PROGRESS | DONE
  dueDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  icon      String   @default("🔔")
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// Education Centre Management Models
// ─────────────────────────────────────────────────────────────

model EducationCentre {
  id       Int          @id @default(autoincrement())
  name     String
  location String
  code     String       @unique
  isActive Boolean      @default(true)
  users    CentreUser[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

model CentreUser {
  id           Int             @id @default(autoincrement())
  email        String          @unique
  passwordHash String // bcrypt hash — never store plaintext
  fullName     String
  role         CentreRole      @default(CENTRE_ADMIN)
  centreId     Int
  centre       EducationCentre @relation(fields: [centreId], references: [id], onDelete: Cascade)
  lastLoginAt  DateTime?
  isActive     Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([centreId])
}

enum CentreRole {
  CENTRE_ADMIN
  CENTRE_STAFF
  CENTRE_TEACHER
}

// ─────────────────────────────────────────────────────────────
// Admin Portal v2 Models
// ─────────────────────────────────────────────────────────────

model PracticeTest {
  id           Int          @id @default(autoincrement())
  title        String
  testType     TestType
  practiceMode PracticeMode @default(FULL)
  focusArea    String?
  durationMins Int          @default(60)
  instructions String?      @db.Text
  passage      String?      @db.Text
  audioUrl     String?
  isPublished  Boolean      @default(false)
  isArchived   Boolean      @default(false)
  createdById  Int
  createdBy    Admin        @relation("CreatedTests", fields: [createdById], references: [id])
  questions    Question[]
  reports      Report[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([testType])
  @@index([isPublished])
  @@index([createdById])
  @@index([practiceMode])
}

model Question {
  id            Int          @id @default(autoincrement())
  testId        Int
  test          PracticeTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  questionText  String       @db.Text
  type          QuestionType @default(MULTIPLE_CHOICE)
  options       Json?
  correctAnswer String
  orderIndex    Int          @default(0)
  reports       Report[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([testId])
  @@index([type])
}

model Report {
  id             Int          @id @default(autoincrement())
  studentId      Int
  student        User         @relation("reports", fields: [studentId], references: [id])
  testId         Int
  test           PracticeTest @relation(fields: [testId], references: [id])
  questionId     Int?
  question       Question?    @relation(fields: [questionId], references: [id])
  type           ReportType   @default(CONTENT_ERROR)
  status         ReportStatus @default(OPEN)
  description    String       @db.Text
  resolvedById   Int?
  resolvedBy     Admin?       @relation("resolvedReports", fields: [resolvedById], references: [id])
  resolutionNote String?      @db.Text
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([studentId])
  @@index([testId])
  @@index([status])
  @@index([type])
}

// ─────────────────────────────────────────────────────────────
// Teacher System Models
// ─────────────────────────────────────────────────────────────

model Lesson {
  id        Int        @id @default(autoincrement())
  title     String
  zoomLink  String
  startTime DateTime
  status    String     @default("SCHEDULED") // SCHEDULED, LIVE, COMPLETED, CANCELLED
  teacherId Int
  teacher   User       @relation("lessons", fields: [teacherId], references: [id], onDelete: Cascade)
  materials Material[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([teacherId])
  @@index([startTime])
  @@index([status])
}

model Material {
  id        Int      @id @default(autoincrement())
  fileName  String
  fileUrl   String
  fileType  String // PDF, DOCX, PPTX, etc.
  teacherId Int
  teacher   User     @relation("materials", fields: [teacherId], references: [id], onDelete: Cascade)
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  lessonId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([lessonId])
  @@index([fileType])
}

model Follow {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   User     @relation("following", fields: [studentId], references: [id], onDelete: Cascade)
  teacherId Int
  teacher   User     @relation("followers", fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([studentId, teacherId])
  @@index([studentId])
  @@index([teacherId])
}
